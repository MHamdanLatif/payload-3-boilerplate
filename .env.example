# Payload + Postgres
DATABASE_URI=postgres://user:password@localhost:5432/lateef_properties
PAYLOAD_SECRET=change-me

# Public site URL (used by Next.js + Payload for OG, sitemap, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Lead capture — Privyr webhook receiving zero-results form submissions
# Leave unset in dev; set in prod to the URL Privyr provides.
PRIVYR_WEBHOOK_URL=

# Cloudflare R2 (S3-compatible) — media storage. The @payloadcms/storage-s3
# plugin in payload.config.ts reads these. Both local dev and Railway prod
# point at the same bucket so admin uploads from either environment are
# persistent and instantly available.
#   S3_BUCKET           — the R2 bucket name (lowercase, no spaces)
#   S3_ENDPOINT         — https://<account-id>.r2.cloudflarestorage.com
#   S3_ACCESS_KEY_ID    — token from R2 → Manage R2 API Tokens
#   S3_SECRET_ACCESS_KEY — secret shown once when creating the token
#   S3_PUBLIC_URL       — Cloudflare-issued public dev URL for the bucket
S3_BUCKET=lateef-properties-media
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# Meta Pixel — fires PageView site-wide via the layout, plus Lead on /thank-you.
# A hardcoded default ID is baked into `src/components/MetaPixel.tsx` so the pixel
# works without env config; set this here to override per-environment (e.g. staging).
NEXT_PUBLIC_META_PIXEL_ID=1007386375371716

# Google Analytics 4 — fires page_view site-wide via the layout (initial load
# + every client-side route change). A hardcoded default measurement ID is
# baked into `src/components/GoogleAnalytics.tsx` (carried over from the old
# site so historical reports stay continuous); set this here to override per
# environment.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-3SH3KB0RZS

# Google Ads conversion (optional) — fires on /thank-you only.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# Search-engine site ownership verification (Google Search Console + Bing Webmaster Tools).
# Inject the token they give you; the meta tag renders automatically when set.
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=

# Manual blog workflow (iteration 14).
# No API keys needed — articles are written in your Claude Max chat and
# cover images generated in Gemini Pro, then pasted into /admin → Blogs.
# The CMS auto-derives excerpt/meta/read-time, auto-detects internal links
# (project + location mentions), and wraps them as Lexical link nodes on
# publish. See docs/blog-workflow.md for the step-by-step.
